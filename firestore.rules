rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - authenticated users can read all, write only their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Patients - staff can manage, anyone can create (public booking)
    match /patients/{patientId} {
      allow read, write, delete: if request.auth != null;
      allow create: if true;
    }

    // Appointments - staff can manage, anyone can create (public booking)
    match /appointments/{appointmentId} {
      allow read, write, delete: if request.auth != null;
      allow create: if true;
    }

    // Treatment plans (subcollection)
    match /patients/{patientId}/treatmentPlan/{planId} {
      allow read, write: if request.auth != null;
    }

    // Clinic settings
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
