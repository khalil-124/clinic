rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - authenticated users only
    match /users/{userId} {
      allow read, write: if request.auth != null;
      // Allow writing during initial setup (first admin creation)
      allow write: if true;
    }

    // Patients - authenticated staff can manage, anyone can create (public booking)
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
      allow create: if true; // Public booking page
    }

    // Appointments - same as patients
    match /appointments/{appointmentId} {
      allow read, write: if request.auth != null;
      allow create: if true; // Public booking page
    }

    // Treatment plans - authenticated only (subcollection)
    match /patients/{patientId}/treatmentPlan/{planId} {
      allow read, write: if request.auth != null;
    }

    // Clinic settings - authenticated only
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
